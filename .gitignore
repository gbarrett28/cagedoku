dist/
build/

# Tool configuration — not part of the project source
.claude/
.serena/
.mcp.json
no_gutter.py

# Generated training data conversion artifacts (keep the canonical accumulated set)
*_train.json
!web/browser_train.json

# Runtime artifacts
sessions/
killer_sudoku/static/main.js

# Test fixture images — download locally, do not commit
tests/fixtures/sudoku/*.jpg
tests/fixtures/sudoku/*.jpeg
tests/fixtures/sudoku/*.png

# node_modules at any level (including root from npx calls)
node_modules/
web/node_modules/
worker/node_modules/

# Local build env — contains Worker URL; injected as CI secret
web/.env.production

# opencv.js committed directly — custom core+imgproc build from build-opencv-wsl.sh.
# CI uses this file; the download step in pages.yml is skipped when it is present.

# tsc emit artefacts — Vite compiles TS natively; tsc runs with --noEmit
web/src/**/*.js
web/vite.config.js
web/vitest.config.js
web/playwright.config.js
